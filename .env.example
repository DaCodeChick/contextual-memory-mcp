PM_PROMPT_DIR=./prompts
PM_DATA_DIR=./data
PM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PM_COLLECTION_NAME=prompt_segments
PM_CHUNK_SIZE=1800
PM_CHUNK_OVERLAP=220
PM_DEFAULT_TOP_K=8
PM_MAX_CONTEXT_CHARS=18000
PM_INCLUDE_GLOBS=*.md,*.txt,*.prompt
PM_EXCLUDE_DIRS=.git,.venv,__pycache__,node_modules
