CM_DATA_DIR=./data
CM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CM_COLLECTION_NAME=context_segments
# CM_STORES_FILE=./stores.json
CM_CHUNK_SIZE=1800
CM_CHUNK_OVERLAP=220
CM_DEFAULT_TOP_K=8
CM_MAX_CONTEXT_CHARS=18000
CM_INCLUDE_GLOBS=*.md,*.txt,*.prompt
CM_EXCLUDE_DIRS=.git,.venv,__pycache__,node_modules
CM_LIFECYCLE_PROMOTION_IMPORTANCE=1.5
CM_LIFECYCLE_PROMOTION_ACCESS_COUNT=3
CM_LIFECYCLE_MINIMUM_CONFIDENCE=0.6
CM_LIFECYCLE_MINIMUM_SOURCE_QUALITY=0.5
CM_LIFECYCLE_ARCHIVE_IMPORTANCE=0.35
CM_LIFECYCLE_ARCHIVE_AFTER_DAYS=90

CM_IMPORTANCE_ACCESS_GAIN=0.05
CM_IMPORTANCE_DECAY_PER_30_DAYS=0.05
CM_IMPORTANCE_DECAY_GRACE_DAYS=30
CM_IMPORTANCE_MINIMUM=0.0
CM_IMPORTANCE_MAXIMUM=2.0
CM_RANKING_RECENCY_HALF_LIFE_DAYS=45

# Neutral defaults for automatically captured direct-user memories.
CM_AUTOMATIC_MEMORY_IMPORTANCE=0.5
CM_AUTOMATIC_MEMORY_CONFIDENCE=1.0
CM_AUTOMATIC_MEMORY_SOURCE_QUALITY=1.0
